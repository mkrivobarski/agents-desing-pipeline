{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "annotation-targets.schema.json",
  "title": "Annotation Targets",
  "description": "Pipeline iteration targets read from Figma sharedPluginData by annotation-scanner. Consumed by targeted-intake-agent.",
  "type": "object",
  "required": ["meta", "targets", "scanner_notes"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["scanned_at", "total_pending", "total_skipped"],
      "additionalProperties": false,
      "properties": {
        "scanned_at": { "type": "string", "format": "date-time" },
        "total_pending": { "type": "integer", "minimum": 0 },
        "total_skipped": { "type": "integer", "minimum": 0 },
        "figma_file_key": { "type": ["string", "null"] }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "node_name", "node_type", "page_name", "scope", "instruction", "intent"],
        "additionalProperties": false,
        "properties": {
          "node_id": { "type": "string", "pattern": "^\\d+:\\d+$", "description": "Figma node ID in 'page:node' format" },
          "node_name": { "type": "string", "minLength": 1 },
          "node_type": {
            "type": "string",
            "enum": ["FRAME", "COMPONENT", "COMPONENT_SET", "INSTANCE", "TEXT", "RECTANGLE", "ELLIPSE", "GROUP", "SECTION", "VECTOR", "BOOLEAN_OPERATION", "LINE", "POLYGON", "STAR"]
          },
          "page_name": { "type": "string", "minLength": 1 },
          "scope": {
            "type": "string",
            "enum": ["frame", "component", "instance", "element"],
            "description": "Derived from node_type by annotation-scanner"
          },
          "instruction": { "type": "string", "minLength": 1, "description": "User-supplied iteration instruction from the plugin panel" },
          "intent": {
            "type": "string",
            "enum": ["iterate", "redesign", "fix", "review"],
            "default": "iterate"
          },
          "constraints": { "type": ["string", "null"], "description": "Optional constraints supplied by user (e.g. 'keep WCAG AA contrast')" },
          "submitted_at": { "type": ["integer", "null"], "description": "Unix timestamp (ms) when the instruction was submitted in Figma" }
        }
      }
    },
    "scanner_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Notes about skipped entries, warnings, or scanner decisions"
    }
  }
}
